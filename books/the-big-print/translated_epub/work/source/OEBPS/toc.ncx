  <ns0:head>
    <ns0:meta name="dtb:uid" content="urn:asin:B0DWKLX9J7-ko-full" />
  </ns0:head>
  <ns0:docTitle>
    <ns0:text>The Big Print: What Happened To America And How Sound Money Will Fix It</ns0:text>
  </ns0:docTitle>
  <ns0:docAuthor>
    <ns0:text>Lepard, Lawrence</ns0:text>
  </ns0:docAuthor>
  <ns0:navMap>
    <ns0:navPoint id="nav0">
      <ns0:navLabel>
        <ns0:text>COVER</ns0:text>
      </ns0:navLabel>
      <ns0:content src="part0000.xhtml" />
    </ns0:navPoint>
    <ns0:navPoint id="nav1">
      <ns0:navLabel>
        <ns0:text>추천사</ns0:text>
      </ns0:navLabel>
      <ns0:content src="part0001.xhtml" />
      <ns0:navPoint id="nav2">
        <ns0:navLabel>
          <ns0:text>DEDICATION</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0004.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav3">
        <ns0:navLabel>
          <ns0:text>서문 맥스 카이저</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0005.xhtml" />
      </ns0:navPoint>
    </ns0:navPoint>
    <ns0:navPoint id="nav4">
      <ns0:navLabel>
        <ns0:text>들어가며</ns0:text>
      </ns0:navLabel>
      <ns0:content src="part0006.xhtml" />
      <ns0:navPoint id="nav5">
        <ns0:navLabel>
          <ns0:text>오프닝 장면</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0007.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav6">
        <ns0:navLabel>
          <ns0:text>머리말</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0008.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav7">
        <ns0:navLabel>
          <ns0:text>핵심 논지</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0009.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav8">
        <ns0:navLabel>
          <ns0:text>저자의 이야기</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0010.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav9">
        <ns0:navLabel>
          <ns0:text>이 책을 읽는 법</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0011.xhtml" />
      </ns0:navPoint>
    </ns0:navPoint>
    <ns0:navPoint id="nav10">
      <ns0:navLabel>
        <ns0:text>제1부 문제</ns0:text>
      </ns0:navLabel>
      <ns0:content src="part0012.xhtml" />
      <ns0:navPoint id="nav11">
        <ns0:navLabel>
          <ns0:text>미국은 망가졌다</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0013.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav12">
        <ns0:navLabel>
          <ns0:text>원인은 인플레이션이다</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0014.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav13">
        <ns0:navLabel>
          <ns0:text>화폐: 건전 화폐와 법정화폐</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0015.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav14">
        <ns0:navLabel>
          <ns0:text>건전 화폐는 도덕의 문제다</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0016.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav15">
        <ns0:navLabel>
          <ns0:text>고전경제학</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0017.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav16">
        <ns0:navLabel>
          <ns0:text>순수한 법정화폐로 가는 길: 1789-1971</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0018.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav17">
        <ns0:navLabel>
          <ns0:text>1971년부터 현재까지: 금융화, 구제금융, 공짜 돈</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0019.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav18">
        <ns0:navLabel>
          <ns0:text>연방준비제도</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0020.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav19">
        <ns0:navLabel>
          <ns0:text>케인즈주의자들과 현대통화이론(MMT)</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0021.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav20">
        <ns0:navLabel>
          <ns0:text>스타인의 법칙</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0022.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav21">
        <ns0:navLabel>
          <ns0:text>아무것도 이 열차를 멈추지 못한다</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0023.xhtml" />
      </ns0:navPoint>
    </ns0:navPoint>
    <ns0:navPoint id="nav22">
      <ns0:navLabel>
        <ns0:text>제2부 해법</ns0:text>
      </ns0:navLabel>
      <ns0:content src="part0024.xhtml" />
      <ns0:navPoint id="nav23">
        <ns0:navLabel>
          <ns0:text>디플레이션을 받아들여라</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0025.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav24">
        <ns0:navLabel>
          <ns0:text>비트코인이 이 문제를 해결했습니다.</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0026.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav25">
        <ns0:navLabel>
          <ns0:text>회의론</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0027.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav26">
        <ns0:navLabel>
          <ns0:text>우리가 구원받을 이유: 분권화</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0028.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav27">
        <ns0:navLabel>
          <ns0:text>이것이 어떻게 전개되는가</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0029.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav28">
        <ns0:navLabel>
          <ns0:text>다음 10년을 위한 로드맵</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0030.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav29">
        <ns0:navLabel>
          <ns0:text>그레샴의 법칙, 인플레이션, 초인플레이션</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0031.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav30">
        <ns0:navLabel>
          <ns0:text>투자 시사점 – 전통 자산</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0032.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav31">
        <ns0:navLabel>
          <ns0:text>투자에 미치는 영향 – 비트코인</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0033.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav32">
        <ns0:navLabel>
          <ns0:text>정책 대응</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0034.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav33">
        <ns0:navLabel>
          <ns0:text>행동 촉구</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0035.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav34">
        <ns0:navLabel>
          <ns0:text>이의 및 반박</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0036.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav35">
        <ns0:navLabel>
          <ns0:text>결론</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0037.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav36">
        <ns0:navLabel>
          <ns0:text>감사의 말</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0038.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav37">
        <ns0:navLabel>
          <ns0:text>계속 연락해 주세요</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0039.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav38">
        <ns0:navLabel>
          <ns0:text>추가 추천 도서</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0040.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav39">
        <ns0:navLabel>
          <ns0:text>부록 A:</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0041.xhtml" />
      </ns0:navPoint>
      <ns0:navPoint id="nav40">
        <ns0:navLabel>
          <ns0:text>부록</ns0:text>
        </ns0:navLabel>
        <ns0:content src="part0042.xhtml" />
      </ns0:navPoint>
    </ns0:navPoint>
  </ns0:navMap>
